# ============================================================
#  Chiki Monsters backend — environment configuration
#  Two profiles below: DEVNET (testing) and MAINNET (live).
# ============================================================

# ---- Network ----
# DEVNET (testing, fake SOL):   NETWORK=devnet
# MAINNET (live, real SOL):     NETWORK=mainnet-beta
NETWORK=devnet

# ---- RPC (must match the network above) ----
# The server makes RPC calls with NO website domain, so this key must be UNRESTRICTED
# (do NOT use a Helius key that's domain-locked to your site — the balance check would fail).
# Devnet:  https://devnet.helius-rpc.com/?api-key=YOUR_UNRESTRICTED_KEY
# Mainnet: https://mainnet.helius-rpc.com/?api-key=YOUR_UNRESTRICTED_KEY
RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_UNRESTRICTED_KEY

# ---- Token gating ----
CHIKI_MINT=CPYrgdAYWFQD74ZtsR8mEBWW7qnrXnegcn7gDMobpump
MIN_HOLD=500000
# VERIFY_HOLDERS:
#   false → everyone is granted a Chiki (use ONLY on devnet, where the real mint doesn't exist).
#   true  → the server checks the wallet's REAL on-chain $CHIKI balance and only grants a Chiki
#           to holders of >= MIN_HOLD. Requires RPC_URL to point at MAINNET.
#   *** For the live launch with real holder gating: set this to true + mainnet RPC_URL. ***
VERIFY_HOLDERS=false

# ---- Wallets (NEVER commit real keys; set these in the host's env, not in git) ----
# Treasury secret key: JSON array (e.g. [12,34,...]) OR a base58 string. Used to SIGN SOL payouts.
# On mainnet this MUST be a fresh, securely-stored wallet — never the devnet throwaway.
TREASURY_SECRET=
# Team wallet address (public key) — receives the team share.
TEAM_WALLET=

# ---- Reward economy (only used once payouts go live) ----
REWARD_RATE_PER_MIN=0.0008     # SOL accrued per eligible minute per player
MAX_CLAIM_SOL=0.05             # cap per single claim
CLAIM_COOLDOWN_SEC=30          # min seconds between a wallet's claims
PORT=8787

# ---- Production storage (set for mainnet; blank = in-memory, dev only) ----
DATABASE_URL=

# ---- Anti-abuse ----
MIN_HOLD_MINUTES=0            # wallet must be "seen" this many minutes before it can claim (set >0 for mainnet)
DAILY_CAP_SOL=1              # global cap on confirmed payouts per rolling 24h

# ---- Admin ----
# Enables GET /admin/reset?key=... to wipe saved game profiles. Leave blank to disable.
# (A fixed token "chikiwipe" also works for testing — remove the /admin/reset route before public launch.)
ADMIN_KEY=

# ---- Chat ----
# Comma-separated wallet addresses allowed to PIN messages / post official announcements in the in-game chat.
# The TEAM_WALLET above is always treated as an admin too. Example: ADMIN_WALLETS=Wallet1,Wallet2
ADMIN_WALLETS=

# ============================================================
#  LIVE HOLDER-GATING QUICK SET (what to put in Render → Environment):
#    NETWORK=mainnet-beta
#    RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_UNRESTRICTED_KEY
#    VERIFY_HOLDERS=true
#    CHIKI_MINT=CPYrgdAYWFQD74ZtsR8mEBWW7qnrXnegcn7gDMobpump
#    MIN_HOLD=500000
# ============================================================

# ---- quest rewards → real $CHIKI (SPL) payout (see REWARD_SECURITY.md) ----
REWARDS_QUEST_ONLY=true       # disable the old time-based SOL accrual
CHIKI_DECIMALS=6              # $CHIKI SPL decimals (pump.fun = 6)
QUEST_MIN_GAP_SEC=20          # min seconds between quest completions (anti-bot)
MIN_CLAIM_CHIKI=20           # smallest claimable pouch
PER_CLAIM_CHIKI=1000         # max $CHIKI per single claim
WALLET_DAILY_CHIKI=2000      # max $CHIKI per wallet per day
POOL_RESERVE_CHIKI=0         # never pay the pool below this floor
BREAKER_HOURLY_CHIKI=100000  # global circuit breaker: max $CHIKI out per rolling hour
